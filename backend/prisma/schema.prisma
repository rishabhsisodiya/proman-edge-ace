generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  // ACE ticketing roles
  CALL_CENTER
  ASM
  ENGINEER
  MANAGER
  ADMIN

  // Proman Edge dashboard roles (BUILD-Role-based Homepages.html)
  MD
  SALES_HEAD_AGGREGATE
  SALES_HEAD_IM_BMH
  ENGINEERING_DESIGN_HEAD
  MANUFACTURING_HEAD
  PROCUREMENT_HEAD
  STORES_HEAD
  QMS_HEAD
  DISPATCH_HEAD
  SERVICE_AFTERSALES_HEAD
  FINANCE_HEAD
}

enum Region {
  NORTH
  SOUTH
  EAST
  WEST
  CENTRAL
  BANGLADESH
}

/// The 5 Frappe Cloud instances (CLAUDE.md sites reference table).
enum FrappeSite {
  PISPL
  ACE
  PROMAX
  BLUESTONE
  QMSPRO
}

/// A business entity/company record living inside a Frappe site (a site can
/// host multiple companies — e.g. pispl.frappe.cloud may host PISPL, Proman
/// Crushing Systems, Dynatek, PROMAN BMH). Modeled as a table, not an enum,
/// since the exact company list is admin-managed, not fixed in code.
model Company {
  id    String        @id @default(uuid())
  name  String        @unique
  site  FrappeSite
  users UserCompany[]
}

model UserCompany {
  userId    String
  companyId String
  user      User    @relation(fields: [userId], references: [id])
  company   Company @relation(fields: [companyId], references: [id])

  @@id([userId, companyId])
}

enum CustomerType {
  DIRECT
  DEALER
  OEM_PARTNER
  GOVERNMENT
  PSU
}

enum AccountStatus {
  ACTIVE
  INACTIVE
  BLACKLISTED
}

enum EquipCategory {
  CRUSHER
  CONVEYOR
  WAGON_TIPPLER
  STACKER_RECLAIMER
  SCREEN
  DRY_MORTAR
  BULK_RECEPTION
  OTHER
}

enum EquipStatus {
  ACTIVE
  UNDER_REPAIR
  DECOMMISSIONED
  SOLD
}

enum WarrantyStatus {
  UNDER_WARRANTY
  EXPIRING_SOON
  OUT_OF_WARRANTY
}

enum ServiceType {
  WARRANTY_REPAIR
  BREAKDOWN_CHARGEABLE
  SCHEDULED_PM
  TECHNICAL_AUDIT
  RETROFIT_UPGRADE
  AMC
  SPARES_SUPPLY_INSTALLATION
}

enum Priority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum Source {
  CUSTOMER_CALL
  CUSTOMER_WHATSAPP
  // FSD §7.1 canonical source — manual-selection tag for now (not an actual
  // self-service portal yet, that's deferred, §7.5).
  CUSTOMER_PORTAL
  CUSTOMER_EMAIL
  AMC_SCHEDULED
  WARRANTY_TRIGGERED
  PREDICTIVE
  INTERNAL
  BULK_IMPORT
  API_PARTNER
}

enum TicketStatus {
  OPEN
  ASSIGNED
  ENGINEER_ASSIGNED
  ACCEPTED
  REACHED_SITE
  WORKING
  PENDING
  ENGINEER_RESOLVED
  ASM_RESOLVED
  CLOSED
}

enum PendingReason {
  AWAITING_PARTS
  AWAITING_CUSTOMER
  AWAITING_APPROVAL
  OTHER
}

enum FsvStatus {
  DRAFT
  SUBMITTED
}

enum NotifChannel {
  EMAIL
  SMS
  WHATSAPP
  PUSH
}

enum AvailabilityStatus {
  AVAILABLE
  ON_VISIT
  ON_LEAVE
  OFF_DUTY
}

enum CallReceivedVia {
  WHATSAPP
  PHONE
  EMAIL
  WALK_IN
  SYSTEM
}

enum NotifStatus {
  SENT
  DELIVERED
  FAILED
}

enum SyncType {
  SCHEDULED
  EVENT
}

enum SyncStatus {
  SUCCESS
  FAILED
  PARTIAL
}

enum ChangeSource {
  WEB_UI
  API
  SYSTEM_JOB
}

model User {
  id                  String              @id @default(uuid())
  fullName            String
  email               String              @unique
  passwordHash        String
  mobile              String
  role                Role
  skillTags           String[]
  isActive            Boolean             @default(true)
  mustChangePassword  Boolean             @default(false)
  tokenVersion        Int                 @default(0)
  failedLoginAttempts Int                 @default(0)
  lockedUntil         DateTime?
  availabilityStatus  AvailabilityStatus?
  currentGpsLat       Float?
  currentGpsLong      Float?
  lastLocationUpdate  DateTime?
  erpnextUserId       String?             @unique
  // Free-text, not an enum — actual levels (Junior/Senior/Lead or otherwise)
  // aren't fixed yet (§5.2 Build Plan note); looked up against BillingRate.level.
  engineerLevel       String?
  regions             UserRegion[]
  companies           UserCompany[]
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  ticketsAsAsm      Ticket[]            @relation("AsmTickets")
  ticketsAsEngineer Ticket[]            @relation("EngineerTickets")
  fsvs              FieldServiceVisit[]
}

model UserRegion {
  userId String
  region Region
  user   User   @relation(fields: [userId], references: [id])

  @@id([userId, region])
}

model Customer {
  id                     String         @id @default(uuid())
  erpnextCustomerId      String?        @unique
  customerName           String
  customerType           CustomerType
  // Nullable: the nightly Customer Sync job (§5.1) resolves this from
  // ERPNext's territory field via RegionMapping. A customer whose territory
  // isn't mapped yet stays null and is flagged via needsReview instead of
  // failing the sync outright.
  region                 Region?
  primaryContactName     String
  primaryContactMobile   String
  primaryContactEmail    String
  secondaryContactName   String?
  secondaryContactMobile String?
  secondaryContactEmail  String?
  billingAddressLine1    String?
  billingAddressLine2    String?
  billingCity            String?
  billingState           String?
  billingPin             String?
  billingCountry         String?
  accountStatus          AccountStatus  @default(ACTIVE)
  gstNumber              String?
  creditTerms            String?
  // Data-quality flag (not a failure) — e.g. unmapped territory or a missing
  // required field on the ERPNext side. Retried every night indefinitely,
  // distinct from CustomerSyncFailure (genuine technical error, capped retry).
  needsReview            Boolean        @default(false)
  reviewReason           String?
  lastSyncedAt           DateTime?
  sites                  CustomerSite[]
  equipment              Equipment[]
  tickets                Ticket[]
  amcContracts           AmcContract[]
  quotations             Quotation[]
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt

  @@index([needsReview])
}

/// Maps ERPNext's messy territory field (state-level, ~33 values with
/// data-quality dupes like "Tamilnadu" vs "Tamil Nadu") onto the app's Region
/// enum. Admin-maintained via its own small screen (not synced from ERPNext —
/// ERPNext has no concept of this app's Region enum).
model RegionMapping {
  id           String   @id @default(uuid())
  erpTerritory String   @unique
  region       Region
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

/// §5.2 Billing Rates config — engineer_level -> hourly rate, for labour
/// line items on chargeable Sales Invoices. `level` is a free-text label
/// (matches User.engineerLevel), not an enum — actual levels aren't fixed yet.
model BillingRate {
  id         String   @id @default(uuid())
  level      String   @unique
  hourlyRate Decimal
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

/// Genuine technical sync failures (DB error, constraint violation, timeout)
/// for a specific ERPNext customer record — distinct from needsReview, which
/// is a data-quality issue, not a failure. Capped retry (5 nightly attempts)
/// rather than the FSD's literal "retry forever," since infinite retry on a
/// permanently-broken record wastes every future run forever.
model CustomerSyncFailure {
  id                String   @id @default(uuid())
  erpnextCustomerId String   @unique
  attemptCount      Int      @default(1)
  lastError         String
  firstFailedAt     DateTime @default(now())
  lastAttemptAt     DateTime @default(now())
}

/// Customers never imported at all because ERPNext has no email AND no
/// mobile for them (client decision: ~81% of real customers, 1,645/2,024,
/// fall into this bucket — not a rare edge case). No Customer row exists for
/// these, so they can't use Customer.needsReview; tracked here instead so
/// Admin can see why, and re-checked every night in case ERP data gets fixed.
model CustomerSyncSkipped {
  id                String   @id @default(uuid())
  erpnextCustomerId String   @unique
  customerName      String
  reason            String
  firstSeenAt       DateTime @default(now())
  lastCheckedAt     DateTime @default(now())
}

model CustomerSite {
  id               String  @id @default(uuid())
  // Not in the FSD's own Customer SQL spec (site_addresses explicitly marked
  // "no" there) — our own addition, sourced from ERPNext Address records
  // linked to a Customer with address_type = 'Shipping'. Nullable + unique
  // so it's only set for sync-created sites, and re-running sync doesn't
  // create duplicates.
  erpnextAddressId String? @unique

  customerId   String
  customer     Customer    @relation(fields: [customerId], references: [id])
  siteName     String
  addressLine1 String
  city         String
  state        String
  pin          String
  gpsLat       Float?
  gpsLong      Float?
  equipment    Equipment[]
  tickets      Ticket[]
}

model Item {
  itemCode                      String               @id
  itemName                      String
  itemGroup                     String
  itemDescription               String?
  uom                           String
  standardRate                  Decimal
  valuationRate                 Decimal?
  // Aggregate convenience total (sum across all warehouses) — per Q4's
  // resolution ("show different warehouse and engineer can select it"),
  // the authoritative per-warehouse breakdown lives in ItemWarehouseStock
  // instead; this field is just a quick "how many total, roughly" figure.
  currentStock                  Float?
  compatibleEquipmentCategories EquipCategory[]
  minimumStockLevel             Float?
  lastSyncedAt                  DateTime?
  warehouseStock                ItemWarehouseStock[]
}

/// Per-warehouse stock breakdown (§5.1.3 Q4) — lets an engineer/ASM pick
/// which warehouse to pull a part from, rather than the app silently
/// assuming one "default" warehouse.
model ItemWarehouseStock {
  id            String   @id @default(uuid())
  itemCode      String
  item          Item     @relation(fields: [itemCode], references: [itemCode])
  warehouse     String
  actualQty     Float
  valuationRate Decimal?
  lastSyncedAt  DateTime @default(now())

  @@unique([itemCode, warehouse])
}

model Equipment {
  id                   String         @id @default(uuid())
  serialNo             String         @unique
  itemCode             String
  itemName             String
  equipmentCategory    EquipCategory
  modelNumber          String?
  customerId           String
  customer             Customer       @relation(fields: [customerId], references: [id])
  // Required in principle, but made optional for now — manual Equipment
  // entry may happen before a customer's sites are known/synced.
  siteId               String?
  site                 CustomerSite?  @relation(fields: [siteId], references: [id])
  gpsLat               Float?
  gpsLong              Float?
  installationDate     DateTime
  deliveryDate         DateTime?
  warrantyStartDate    DateTime
  warrantyEndDate      DateTime
  warrantyPeriodMonths Int
  warrantyStatus       WarrantyStatus
  operatingHoursMeter  Float?
  status               EquipStatus    @default(ACTIVE)
  skillTagsRequired    String[]
  notes                String?
  erpnextSerialNo      String?
  // Many-to-many: an equipment can have more than one AMC Contract over its
  // lifetime (e.g. last year's + this year's renewal both present per
  // §14.5's overlapping-contracts rule — system picks the later start_date
  // one as active). A single FK couldn't represent that.
  amcContracts         AmcContract[]
  tickets              Ticket[]
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
}

model Ticket {
  id                       String              @id @default(uuid())
  ticketNo                 String              @unique
  source                   Source
  // Nullable — client request: may genuinely be unknown at ticket creation
  // (Call Center hasn't diagnosed it yet). Set later by ASM/Engineer/Manager/
  // Admin via updateServiceType() once it's actually known.
  serviceType              ServiceType?
  priority                 Priority
  status                   TicketStatus        @default(OPEN)
  subject                  String
  description              String
  customerId               String
  customer                 Customer            @relation(fields: [customerId], references: [id])
  equipmentId              String?
  equipment                Equipment?          @relation(fields: [equipmentId], references: [id])
  siteId                   String?
  site                     CustomerSite?       @relation(fields: [siteId], references: [id])
  warrantyStatusAtCreation WarrantyStatus?
  warrantyEligible         Boolean             @default(false)
  overrideReason           String?
  slaResponseDue           DateTime?
  slaResolutionDue         DateTime?
  slaResponseMet           Boolean             @default(false)
  slaResolutionMet         Boolean             @default(false)
  slaPolicyId              String?
  callReceivedAt           DateTime            @default(now())
  callReceivedVia          CallReceivedVia?
  createdByUserId          String
  assignedAsmId            String?
  assignedAsm              User?               @relation("AsmTickets", fields: [assignedAsmId], references: [id])
  assignedEngineerId       String?
  assignedEngineer         User?               @relation("EngineerTickets", fields: [assignedEngineerId], references: [id])
  rejectionCount           Int                 @default(0)
  rejectionReasons         Json                @default("[]")
  pendingReason            PendingReason?
  pendingNotes             String?
  resolutionSummary        String?
  csatSurveySent           Boolean             @default(false)
  csatScore                Int?
  csatResponseText         String?
  erpnextInvoiceId         String?
  // FSD Analysis decisions log, 20 Jul 2026: "For the 24-hour same-customer/
  // same-equipment duplicate flag, add a manual merge or dismiss action
  // alongside the automatic merge." Automatic merge (AUTO_MERGE_SOURCES) never
  // creates a second ticket at all, so it needs neither field. This pair is
  // only for the manual/customer-initiated case, where a second ticket *is*
  // created with just a free-text audit note today — these make the flag
  // structured/actionable instead of only a line of timeline text.
  possibleDuplicateOfId    String?
  possibleDuplicateOf      Ticket?             @relation("TicketDuplicateFlag", fields: [possibleDuplicateOfId], references: [id])
  possibleDuplicatesOfThis Ticket[]            @relation("TicketDuplicateFlag")
  duplicateFlagResolved    Boolean             @default(false)
  tags                     String[]
  visits                   FieldServiceVisit[]
  auditLog                 TicketAuditLog[]
  notifications            NotificationLog[]
  quotations               Quotation[]
  // Direct Deliveries only (the non-chargeable path with no Quotation) —
  // chargeable-path Deliveries are reached via quotations[].deliveries.
  directDeliveries         Delivery[]
  createdAt                DateTime            @default(now())
  updatedAt                DateTime            @updatedAt
  closedAt                 DateTime?

  @@index([status])
  @@index([slaResolutionDue])
  @@index([assignedAsmId])
  @@index([assignedEngineerId])
}

model TicketAuditLog {
  id              String       @id @default(uuid())
  ticketId        String
  ticket          Ticket       @relation(fields: [ticketId], references: [id])
  fieldName       String
  oldValue        String?
  newValue        String?
  changedByUserId String
  changedAt       DateTime     @default(now())
  changeSource    ChangeSource
  ipAddress       String?

  @@index([ticketId])
}

model FieldServiceVisit {
  id                     String            @id @default(uuid())
  visitNo                String            @unique
  ticketId               String
  ticket                 Ticket            @relation(fields: [ticketId], references: [id])
  visitNumber            Int
  engineerId             String
  engineer               User              @relation(fields: [engineerId], references: [id])
  visitDate              DateTime
  travelStartTime        DateTime?
  siteArrivalTime        DateTime?
  workStartTime          DateTime?
  workEndTime            DateTime?
  workPerformed          String?
  findingsRootCause      String?
  recommendations        String?
  customerRepName        String?
  customerRepDesignation String?
  customerSignOff        Boolean           @default(false)
  customerSignatureUrl   String?
  gpsLatAtCheckin        Float?
  gpsLongAtCheckin       Float?
  // §14.2: submit requires parts consumed OR this explicit flag — an empty
  // parts[] array alone can't distinguish "no parts used" from "forgot to log it".
  noPartsUsed            Boolean           @default(false)
  status                 FsvStatus         @default(DRAFT)
  submittedAt            DateTime?
  submittedBy            String?
  erpnextStockEntryId    String?
  visitReportUrl         String?
  parts                  FsvPartConsumed[]
  photos                 FsvPhoto[]
}

model FsvPartConsumed {
  id          String            @id @default(uuid())
  visitId     String
  visit       FieldServiceVisit @relation(fields: [visitId], references: [id])
  itemCode    String
  itemName    String
  qty         Decimal
  uom         String
  warehouse   String
  rate        Decimal
  sellingRate Decimal
  amount      Decimal
}

model FsvPhoto {
  id      String            @id @default(uuid())
  visitId String
  visit   FieldServiceVisit @relation(fields: [visitId], references: [id])
  url     String
  caption String?
}

model NotificationLog {
  id               String       @id @default(uuid())
  ticketId         String?
  ticket           Ticket?      @relation(fields: [ticketId], references: [id])
  channel          NotifChannel @default(EMAIL)
  recipient        String
  templateName     String
  sentAt           DateTime     @default(now())
  deliveryStatus   NotifStatus
  gatewayMessageId String?
}

/// Daily capture of Manufacturing homepage KPIs — powers the "vs yesterday"
/// trend on the KPI cards. Written once a day by a scheduled job (see
/// dashboards/manufacturing/manufacturing-snapshot.cron.ts); date is the
/// natural key (YYYY-MM-DD string, not a DateTime, to avoid timezone drift
/// on a value that's always meant as a plain calendar day).
model ManufacturingKpiSnapshot {
  date           String @id
  activeWOs      Int
  completedToday Int
  delayed        Int
  atRisk         Int
  onHold         Int
}

/// Daily capture of Finance homepage KPIs (group totals, pre site-sheet merge).
model FinanceKpiSnapshot {
  date               String  @id
  cashBank           Decimal
  overdueReceivables Decimal
  revenueMtd         Decimal
  gstLiability       Decimal
  payablesDue7d      Decimal
}

/// Daily capture of Procurement homepage KPIs.
model ProcurementKpiSnapshot {
  date          String  @id
  prsPending    Int
  openPOs       Int
  overduePOs    Int
  criticalStock Int
  spendMtd      Decimal
}

/// Single-row settings table (id fixed at 1) — gross margin target used by the
/// Finance dashboard's GM gauge, editable per-entity from the dashboard's
/// settings panel. Replaces the old finance_settings.json file store.
model FinanceSettings {
  id               Int   @id @default(1)
  defaultGmTarget  Float @default(24)
  gmTargetByEntity Json  @default("{}")
}

enum PartsCoverage {
  NONE
  CONSUMABLES_ONLY
  ALL_PARTS
}

enum RenewalStatus {
  ACTIVE
  RENEWAL_DUE
  FINAL_NOTICE
  LAPSED
  RENEWED
}

enum VisitStatus {
  SCHEDULED_PENDING
  COMPLETED
  RESCHEDULED
}

/// Scaffolded schema-only per Days 1-3 (Build Plan) — entity logic/engine
/// (nightly auto-ticket job, renewal alerts) is Days 4-10, T2.
model AmcContract {
  id                  String              @id @default(uuid())
  contractReferenceNo String              @unique
  customerId          String
  customer            Customer            @relation(fields: [customerId], references: [id])
  startDate           DateTime
  endDate             DateTime
  contractValue       Decimal
  visitsIncluded      Int
  partsCoverage       PartsCoverage
  scopeOfServices     String?
  exclusions          String?
  renewalStatus       RenewalStatus       @default(ACTIVE)
  owningAsmId         String?
  previousContractId  String?
  signedAgreementUrl  String?
  // Many-to-many: coverage is per-equipment (≥1 required), and one equipment
  // can be covered by more than one contract over time (see Equipment.amcContracts).
  coveredEquipment    Equipment[]
  scheduledVisits     AmcScheduledVisit[]
  quotations          Quotation[]
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
}

model AmcScheduledVisit {
  id             String      @id @default(uuid())
  contractId     String
  contract       AmcContract @relation(fields: [contractId], references: [id])
  visitSeqNo     Int
  plannedDate    DateTime
  equipmentId    String
  notes          String?
  status         VisitStatus @default(SCHEDULED_PENDING)
  linkedTicketId String?
  actualDate     DateTime?
}

enum QuotationStatus {
  DRAFT
  SENT
  CUSTOMER_ACCEPTED
  PO_RECEIVED
  CONVERTED_TO_SALES_ORDER
  EXPIRED
  CANCELLED
}

/// Scaffolded schema-only per Days 1-3 (Build Plan) — CS Support screens, GST
/// computation, quotation PDF are Days 4-10, T3.
model Quotation {
  id                    String          @id @default(uuid())
  quotationNo           String          @unique
  ticketId              String
  ticket                Ticket          @relation(fields: [ticketId], references: [id])
  customerId            String
  customer              Customer        @relation(fields: [customerId], references: [id])
  createdByUserId       String
  amcContractId         String?
  amcContract           AmcContract?    @relation(fields: [amcContractId], references: [id])
  quotationDate         DateTime        @default(now())
  validUntil            DateTime
  labourCharges         Decimal?
  subtotal              Decimal?
  taxAmount             Decimal?
  grandTotal            Decimal?
  notesToCustomer       String?
  termsAndConditions    String?
  status                QuotationStatus @default(DRAFT)
  sentAt                DateTime?
  customerPoNumber      String?
  customerPoDate        DateTime?
  customerPoDocUrl      String?
  erpnextQuotationId    String?
  erpnextSalesOrderId   String?
  // Added per Shivam's 2026-07-23 revised pipeline: Delivery Note is raised
  // MANUALLY in ERPNext (not created by ACE) — its id is only fetched back
  // via webhook/poll. Sales Invoice is created as DRAFT once the Sales
  // Order reaches ERPNext status "To Bill", also webhook/poll-driven, not
  // tied to ACE ticket close anymore.
  erpnextDeliveryNoteId String?
  erpnextInvoiceId      String?
  deliveryStatus        DeliveryStatus  @default(PENDING)
  items                 QuotationItem[]
  deliveries            Delivery[]
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
}

/// Itemized quotation lines — editable during Negotiation (§ ACE_Ticket_Master_Flow.png).
model QuotationItem {
  id          String    @id @default(uuid())
  quotationId String
  quotation   Quotation @relation(fields: [quotationId], references: [id])
  itemCode    String
  itemName    String
  qty         Decimal
  uom         String
  unitPrice   Decimal
  taxAmount   Decimal   @default(0)
  lineTotal   Decimal
}

enum DeliveryStatus {
  PENDING
  PARTIAL
  DELIVERED
}

/// Scaffolded per Q13 (FSD Analysis doc) — no field spec exists in the FSD
/// itself, this is our proposed minimal set, pending client confirmation.
///
/// quotationId is optional and ticketId exists directly per
/// ACE_Ticket_Master_Flow.png's non-chargeable branch — that path goes
/// straight from "Chargeable? No" to an ERPNext Sales Order with no
/// Quotation box at all, so a Delivery there has nothing to link via
/// quotationId. Exactly one of quotationId / ticketId must be set (enforced
/// in the service layer, not a DB constraint).
model Delivery {
  id                    String         @id @default(uuid())
  quotationId           String?
  quotation             Quotation?     @relation(fields: [quotationId], references: [id])
  ticketId              String?
  ticket                Ticket?        @relation(fields: [ticketId], references: [id])
  // Only set on the direct (no-Quotation) path — the chargeable path's SO id
  // already lives on Quotation.erpnextSalesOrderId.
  erpnextSalesOrderId   String?
  // Set whenever the ERPNext write is skipped (e.g. no FSV parts logged yet,
  // or the customer has no erpnextCustomerId) or fails — previously this was
  // only logged server-side, leaving erpnextSalesOrderId silently null with
  // no way to tell "not tried yet" from "tried and failed" from the UI.
  erpnextSyncNote       String?
  erpnextDeliveryNoteId String?
  deliveryDate          DateTime?
  status                DeliveryStatus @default(PENDING)
  trackingNotes         String?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
}

model SyncLog {
  id           String     @id @default(uuid())
  syncType     SyncType
  entity       String
  erpDoctype   String
  status       SyncStatus
  errorMessage String?
  payload      Json?
  startedAt    DateTime   @default(now())
  completedAt  DateTime?
}
