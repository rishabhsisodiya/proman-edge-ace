generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  // ACE ticketing roles
  CALL_CENTER
  ASM
  ENGINEER
  MANAGER
  ADMIN

  // Proman Edge dashboard roles (BUILD-Role-based Homepages.html)
  MD
  SALES_HEAD_AGGREGATE
  SALES_HEAD_IM_BMH
  ENGINEERING_DESIGN_HEAD
  MANUFACTURING_HEAD
  PROCUREMENT_HEAD
  STORES_HEAD
  QMS_HEAD
  DISPATCH_HEAD
  SERVICE_AFTERSALES_HEAD
  FINANCE_HEAD
}

enum Region {
  NORTH
  SOUTH
  EAST
  WEST
  CENTRAL
  BANGLADESH
}

/// The 5 Frappe Cloud instances (CLAUDE.md sites reference table).
enum FrappeSite {
  PISPL
  ACE
  PROMAX
  BLUESTONE
  QMSPRO
}

/// A business entity/company record living inside a Frappe site (a site can
/// host multiple companies — e.g. pispl.frappe.cloud may host PISPL, Proman
/// Crushing Systems, Dynatek, PROMAN BMH). Modeled as a table, not an enum,
/// since the exact company list is admin-managed, not fixed in code.
model Company {
  id    String        @id @default(uuid())
  name  String        @unique
  site  FrappeSite
  users UserCompany[]
}

model UserCompany {
  userId    String
  companyId String
  user      User    @relation(fields: [userId], references: [id])
  company   Company @relation(fields: [companyId], references: [id])

  @@id([userId, companyId])
}

enum CustomerType {
  DIRECT
  DEALER
  OEM_PARTNER
  GOVERNMENT
  PSU
}

enum AccountStatus {
  ACTIVE
  INACTIVE
  BLACKLISTED
}

enum EquipCategory {
  CRUSHER
  CONVEYOR
  WAGON_TIPPLER
  STACKER_RECLAIMER
  SCREEN
  DRY_MORTAR
  BULK_RECEPTION
  OTHER
}

enum EquipStatus {
  ACTIVE
  UNDER_REPAIR
  DECOMMISSIONED
  SOLD
}

enum WarrantyStatus {
  UNDER_WARRANTY
  EXPIRING_SOON
  OUT_OF_WARRANTY
}

enum ServiceType {
  WARRANTY_REPAIR
  BREAKDOWN_CHARGEABLE
  SCHEDULED_PM
  TECHNICAL_AUDIT
  RETROFIT_UPGRADE
  AMC
  SPARES_SUPPLY_INSTALLATION
}

enum Priority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum Source {
  CUSTOMER_CALL
  CUSTOMER_WHATSAPP
  // FSD §7.1 canonical source — manual-selection tag for now (not an actual
  // self-service portal yet, that's deferred, §7.5).
  CUSTOMER_PORTAL
  CUSTOMER_EMAIL
  AMC_SCHEDULED
  WARRANTY_TRIGGERED
  PREDICTIVE
  INTERNAL
  BULK_IMPORT
  API_PARTNER
}

enum TicketStatus {
  OPEN
  ASSIGNED
  ENGINEER_ASSIGNED
  ACCEPTED
  REACHED_SITE
  WORKING
  PENDING
  ENGINEER_RESOLVED
  ASM_RESOLVED
  CLOSED
}

enum PendingReason {
  AWAITING_PARTS
  AWAITING_CUSTOMER
  AWAITING_APPROVAL
  OTHER
}

enum FsvStatus {
  DRAFT
  SUBMITTED
}

enum NotifChannel {
  EMAIL
  SMS
  WHATSAPP
  PUSH
}

enum AvailabilityStatus {
  AVAILABLE
  ON_VISIT
  ON_LEAVE
  OFF_DUTY
}

enum CallReceivedVia {
  WHATSAPP
  PHONE
  EMAIL
  WALK_IN
  SYSTEM
}

enum NotifStatus {
  SENT
  DELIVERED
  FAILED
}

enum SyncType {
  SCHEDULED
  EVENT
}

enum SyncStatus {
  SUCCESS
  FAILED
  PARTIAL
}

enum ChangeSource {
  WEB_UI
  API
  SYSTEM_JOB
}

model User {
  id                  String              @id @default(uuid())
  fullName            String
  email               String              @unique
  passwordHash        String
  mobile              String
  role                Role
  skillTags           String[]
  isActive            Boolean             @default(true)
  mustChangePassword  Boolean             @default(false)
  tokenVersion        Int                 @default(0)
  failedLoginAttempts Int                 @default(0)
  lockedUntil         DateTime?
  availabilityStatus  AvailabilityStatus?
  currentGpsLat       Float?
  currentGpsLong      Float?
  lastLocationUpdate  DateTime?
  erpnextUserId       String?             @unique
  regions             UserRegion[]
  companies           UserCompany[]
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  ticketsAsAsm      Ticket[]            @relation("AsmTickets")
  ticketsAsEngineer Ticket[]            @relation("EngineerTickets")
  fsvs              FieldServiceVisit[]
}

model UserRegion {
  userId String
  region Region
  user   User   @relation(fields: [userId], references: [id])

  @@id([userId, region])
}

model Customer {
  id                     String         @id @default(uuid())
  erpnextCustomerId      String?        @unique
  customerName           String
  customerType           CustomerType
  // Nullable: the nightly Customer Sync job (§5.1) resolves this from
  // ERPNext's territory field via RegionMapping. A customer whose territory
  // isn't mapped yet stays null and is flagged via needsReview instead of
  // failing the sync outright.
  region                 Region?
  primaryContactName     String
  primaryContactMobile   String
  primaryContactEmail    String
  secondaryContactName   String?
  secondaryContactMobile String?
  secondaryContactEmail  String?
  billingAddressLine1    String?
  billingAddressLine2    String?
  billingCity            String?
  billingState           String?
  billingPin             String?
  billingCountry         String?
  accountStatus          AccountStatus  @default(ACTIVE)
  gstNumber              String?
  creditTerms            String?
  // Data-quality flag (not a failure) — e.g. unmapped territory or a missing
  // required field on the ERPNext side. Retried every night indefinitely,
  // distinct from CustomerSyncFailure (genuine technical error, capped retry).
  needsReview            Boolean        @default(false)
  reviewReason           String?
  lastSyncedAt           DateTime?
  sites                  CustomerSite[]
  equipment              Equipment[]
  tickets                Ticket[]
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt

  @@index([needsReview])
}

/// Maps ERPNext's messy territory field (state-level, ~33 values with
/// data-quality dupes like "Tamilnadu" vs "Tamil Nadu") onto the app's Region
/// enum. Admin-maintained via its own small screen (not synced from ERPNext —
/// ERPNext has no concept of this app's Region enum).
model RegionMapping {
  id           String   @id @default(uuid())
  erpTerritory String   @unique
  region       Region
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

/// Genuine technical sync failures (DB error, constraint violation, timeout)
/// for a specific ERPNext customer record — distinct from needsReview, which
/// is a data-quality issue, not a failure. Capped retry (5 nightly attempts)
/// rather than the FSD's literal "retry forever," since infinite retry on a
/// permanently-broken record wastes every future run forever.
model CustomerSyncFailure {
  id                String   @id @default(uuid())
  erpnextCustomerId String   @unique
  attemptCount      Int      @default(1)
  lastError         String
  firstFailedAt     DateTime @default(now())
  lastAttemptAt     DateTime @default(now())
}

/// Customers never imported at all because ERPNext has no email AND no
/// mobile for them (client decision: ~81% of real customers, 1,645/2,024,
/// fall into this bucket — not a rare edge case). No Customer row exists for
/// these, so they can't use Customer.needsReview; tracked here instead so
/// Admin can see why, and re-checked every night in case ERP data gets fixed.
model CustomerSyncSkipped {
  id                String   @id @default(uuid())
  erpnextCustomerId String   @unique
  customerName      String
  reason            String
  firstSeenAt       DateTime @default(now())
  lastCheckedAt     DateTime @default(now())
}

model CustomerSite {
  id           String      @id @default(uuid())
  customerId   String
  customer     Customer    @relation(fields: [customerId], references: [id])
  siteName     String
  addressLine1 String
  city         String
  state        String
  pin          String
  gpsLat       Float?
  gpsLong      Float?
  equipment    Equipment[]
  tickets      Ticket[]
}

model Item {
  itemCode                      String          @id
  itemName                      String
  itemGroup                     String
  itemDescription               String?
  uom                           String
  standardRate                  Decimal
  valuationRate                 Decimal?
  currentStock                  Float?
  compatibleEquipmentCategories EquipCategory[]
  minimumStockLevel             Float?
  lastSyncedAt                  DateTime?
}

model Equipment {
  id                   String         @id @default(uuid())
  serialNo             String         @unique
  itemCode             String
  itemName             String
  equipmentCategory    EquipCategory
  modelNumber          String?
  customerId           String
  customer             Customer       @relation(fields: [customerId], references: [id])
  siteId               String
  site                 CustomerSite   @relation(fields: [siteId], references: [id])
  gpsLat               Float?
  gpsLong              Float?
  installationDate     DateTime
  deliveryDate         DateTime?
  warrantyStartDate    DateTime
  warrantyEndDate      DateTime
  warrantyPeriodMonths Int
  warrantyStatus       WarrantyStatus
  operatingHoursMeter  Float?
  status               EquipStatus    @default(ACTIVE)
  skillTagsRequired    String[]
  notes                String?
  erpnextSerialNo      String?
  tickets              Ticket[]
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
}

model Ticket {
  id                       String              @id @default(uuid())
  ticketNo                 String              @unique
  source                   Source
  // Nullable — client request: may genuinely be unknown at ticket creation
  // (Call Center hasn't diagnosed it yet). Set later by ASM/Engineer/Manager/
  // Admin via updateServiceType() once it's actually known.
  serviceType              ServiceType?
  priority                 Priority
  status                   TicketStatus        @default(OPEN)
  subject                  String
  description              String
  customerId               String
  customer                 Customer            @relation(fields: [customerId], references: [id])
  equipmentId              String?
  equipment                Equipment?          @relation(fields: [equipmentId], references: [id])
  siteId                   String?
  site                     CustomerSite?       @relation(fields: [siteId], references: [id])
  warrantyStatusAtCreation WarrantyStatus?
  warrantyEligible         Boolean             @default(false)
  overrideReason           String?
  slaResponseDue           DateTime?
  slaResolutionDue         DateTime?
  slaResponseMet           Boolean             @default(false)
  slaResolutionMet         Boolean             @default(false)
  slaPolicyId              String?
  callReceivedAt           DateTime            @default(now())
  callReceivedVia          CallReceivedVia?
  createdByUserId          String
  assignedAsmId            String?
  assignedAsm              User?               @relation("AsmTickets", fields: [assignedAsmId], references: [id])
  assignedEngineerId       String?
  assignedEngineer         User?               @relation("EngineerTickets", fields: [assignedEngineerId], references: [id])
  rejectionCount           Int                 @default(0)
  rejectionReasons         Json                @default("[]")
  pendingReason            PendingReason?
  pendingNotes             String?
  resolutionSummary        String?
  csatSurveySent           Boolean             @default(false)
  csatScore                Int?
  csatResponseText         String?
  erpnextInvoiceId         String?
  tags                     String[]
  visits                   FieldServiceVisit[]
  auditLog                 TicketAuditLog[]
  notifications            NotificationLog[]
  createdAt                DateTime            @default(now())
  updatedAt                DateTime            @updatedAt
  closedAt                 DateTime?

  @@index([status])
  @@index([slaResolutionDue])
  @@index([assignedAsmId])
  @@index([assignedEngineerId])
}

model TicketAuditLog {
  id              String       @id @default(uuid())
  ticketId        String
  ticket          Ticket       @relation(fields: [ticketId], references: [id])
  fieldName       String
  oldValue        String?
  newValue        String?
  changedByUserId String
  changedAt       DateTime     @default(now())
  changeSource    ChangeSource
  ipAddress       String?

  @@index([ticketId])
}

model FieldServiceVisit {
  id                     String            @id @default(uuid())
  visitNo                String            @unique
  ticketId               String
  ticket                 Ticket            @relation(fields: [ticketId], references: [id])
  visitNumber            Int
  engineerId             String
  engineer               User              @relation(fields: [engineerId], references: [id])
  visitDate              DateTime
  travelStartTime        DateTime?
  siteArrivalTime        DateTime?
  workStartTime          DateTime?
  workEndTime            DateTime?
  workPerformed          String?
  findingsRootCause      String?
  recommendations        String?
  customerRepName        String?
  customerRepDesignation String?
  customerSignOff        Boolean           @default(false)
  customerSignatureUrl   String?
  gpsLatAtCheckin        Float?
  gpsLongAtCheckin       Float?
  status                 FsvStatus         @default(DRAFT)
  submittedAt            DateTime?
  submittedBy            String?
  erpnextStockEntryId    String?
  visitReportUrl         String?
  parts                  FsvPartConsumed[]
  photos                 FsvPhoto[]
}

model FsvPartConsumed {
  id          String            @id @default(uuid())
  visitId     String
  visit       FieldServiceVisit @relation(fields: [visitId], references: [id])
  itemCode    String
  itemName    String
  qty         Decimal
  uom         String
  warehouse   String
  rate        Decimal
  sellingRate Decimal
  amount      Decimal
}

model FsvPhoto {
  id      String            @id @default(uuid())
  visitId String
  visit   FieldServiceVisit @relation(fields: [visitId], references: [id])
  url     String
  caption String?
}

model NotificationLog {
  id               String       @id @default(uuid())
  ticketId         String?
  ticket           Ticket?      @relation(fields: [ticketId], references: [id])
  channel          NotifChannel @default(EMAIL)
  recipient        String
  templateName     String
  sentAt           DateTime     @default(now())
  deliveryStatus   NotifStatus
  gatewayMessageId String?
}

/// Daily capture of Manufacturing homepage KPIs — powers the "vs yesterday"
/// trend on the KPI cards. Written once a day by a scheduled job (see
/// dashboards/manufacturing/manufacturing-snapshot.cron.ts); date is the
/// natural key (YYYY-MM-DD string, not a DateTime, to avoid timezone drift
/// on a value that's always meant as a plain calendar day).
model ManufacturingKpiSnapshot {
  date           String @id
  activeWOs      Int
  completedToday Int
  delayed        Int
  atRisk         Int
  onHold         Int
}

/// Daily capture of Finance homepage KPIs (group totals, pre site-sheet merge).
model FinanceKpiSnapshot {
  date               String  @id
  cashBank           Decimal
  overdueReceivables Decimal
  revenueMtd         Decimal
  gstLiability       Decimal
  payablesDue7d      Decimal
}

/// Daily capture of Procurement homepage KPIs.
model ProcurementKpiSnapshot {
  date          String  @id
  prsPending    Int
  openPOs       Int
  overduePOs    Int
  criticalStock Int
  spendMtd      Decimal
}

/// Single-row settings table (id fixed at 1) — gross margin target used by the
/// Finance dashboard's GM gauge, editable per-entity from the dashboard's
/// settings panel. Replaces the old finance_settings.json file store.
model FinanceSettings {
  id               Int   @id @default(1)
  defaultGmTarget  Float @default(24)
  gmTargetByEntity Json  @default("{}")
}

enum PartsCoverage {
  NONE
  CONSUMABLES_ONLY
  ALL_PARTS
}

enum RenewalStatus {
  ACTIVE
  RENEWAL_DUE
  FINAL_NOTICE
  LAPSED
  RENEWED
}

enum VisitStatus {
  SCHEDULED_PENDING
  COMPLETED
  RESCHEDULED
}

/// Scaffolded schema-only per Days 1-3 (Build Plan) — entity logic/engine
/// (nightly auto-ticket job, renewal alerts) is Days 4-10, T2.
model AmcContract {
  id                  String              @id @default(uuid())
  contractReferenceNo String              @unique
  customerId          String
  startDate           DateTime
  endDate             DateTime
  contractValue       Decimal
  visitsIncluded      Int
  partsCoverage       PartsCoverage
  scopeOfServices     String?
  exclusions          String?
  renewalStatus       RenewalStatus       @default(ACTIVE)
  owningAsmId         String?
  previousContractId  String?
  signedAgreementUrl  String?
  scheduledVisits     AmcScheduledVisit[]
  quotations          Quotation[]
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
}

model AmcScheduledVisit {
  id             String      @id @default(uuid())
  contractId     String
  contract       AmcContract @relation(fields: [contractId], references: [id])
  visitSeqNo     Int
  plannedDate    DateTime
  equipmentId    String
  notes          String?
  status         VisitStatus @default(SCHEDULED_PENDING)
  linkedTicketId String?
  actualDate     DateTime?
}

enum QuotationStatus {
  DRAFT
  SENT
  CUSTOMER_ACCEPTED
  PO_RECEIVED
  CONVERTED_TO_SALES_ORDER
  EXPIRED
  CANCELLED
}

/// Scaffolded schema-only per Days 1-3 (Build Plan) — CS Support screens, GST
/// computation, quotation PDF are Days 4-10, T3.
model Quotation {
  id                  String          @id @default(uuid())
  quotationNo         String          @unique
  ticketId            String
  customerId          String
  createdByUserId     String
  amcContractId       String?
  amcContract         AmcContract?    @relation(fields: [amcContractId], references: [id])
  quotationDate       DateTime        @default(now())
  validUntil          DateTime
  labourCharges       Decimal?
  subtotal            Decimal?
  taxAmount           Decimal?
  grandTotal          Decimal?
  notesToCustomer     String?
  termsAndConditions  String?
  status              QuotationStatus @default(DRAFT)
  sentAt              DateTime?
  customerPoNumber    String?
  customerPoDate      DateTime?
  customerPoDocUrl    String?
  erpnextQuotationId  String?
  erpnextSalesOrderId String?
  deliveryStatus      DeliveryStatus  @default(PENDING)
  deliveries          Delivery[]
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
}

enum DeliveryStatus {
  PENDING
  PARTIAL
  DELIVERED
}

/// Scaffolded per Q13 (FSD Analysis doc) — no field spec exists in the FSD
/// itself, this is our proposed minimal set, pending client confirmation.
model Delivery {
  id                    String         @id @default(uuid())
  quotationId           String
  quotation             Quotation      @relation(fields: [quotationId], references: [id])
  erpnextDeliveryNoteId String?
  deliveryDate          DateTime?
  status                DeliveryStatus @default(PENDING)
  trackingNotes         String?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
}

model SyncLog {
  id           String     @id @default(uuid())
  syncType     SyncType
  entity       String
  erpDoctype   String
  status       SyncStatus
  errorMessage String?
  payload      Json?
  startedAt    DateTime   @default(now())
  completedAt  DateTime?
}
